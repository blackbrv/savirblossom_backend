{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",

        "strict": true,
        "skipLibCheck": true,

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": false,
        "isolatedModules": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        }
    }
}
